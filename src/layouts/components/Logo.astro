---
import config from "@/config/config.json";
import { url } from "@/lib/utils/url";
const { src } = Astro.props;
const {
  logo,
  logo_width,
  logo_height,
  logo_text,
  title,
}: {
  logo: string;
  logo_width: string;
  logo_height: string;
  logo_text: string;
  title: string;
} = config.site;

const logoSrc = src ?? logo;
const width = logo_width.replace("px", "");
const height = logo_height.replace("px", "");
---

<a href={url("/")} class="navbar-brand inline-flex items-center gap-2">
  {
    logoSrc && (
      <img
        src={url(logoSrc)}
        alt={title}
        width={width}
        height={height}
        style={{ width: `${width}px`, height: `${height}px` }}
      />
    )
  }
  {
    logo_text ? (
      <span class="text-xl font-bold">{logo_text}</span>
    ) : (
      !logoSrc && title
    )
  }
</a>
